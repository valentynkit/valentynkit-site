---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from './Layout.astro';
import Subscribe from '../components/Subscribe.astro';

type Entry = CollectionEntry<'blog'>;
type Props = Entry['data'] & {
	prev?: Pick<Entry, 'id'> & { data: Pick<Entry['data'], 'title'> } | null;
	next?: Pick<Entry, 'id'> & { data: Pick<Entry['data'], 'title'> } | null;
};

const { title, description, pubDate, updatedDate, prev, next } = Astro.props;
---

<Layout title={title} description={description} article={{ pubDate, updatedDate }}>
	<article>
		<header class="post-header rise">
			<p class="eyebrow">
				<FormattedDate date={pubDate} />
				{updatedDate && <span> · updated <FormattedDate date={updatedDate} /></span>}
			</p>
			<h1>{title.replace(/-/g, '‑')}</h1>
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>

	{
		(prev || next) && (
			<nav class="post-nav">
				<span>{prev && <a href={`/blog/${prev.id}/`}>← {prev.data.title}</a>}</span>
				<span class="next">{next && <a href={`/blog/${next.id}/`}>{next.data.title} →</a>}</span>
			</nav>
		)
	}
	<p class="meta backlink"><a href="/blog/">← all writing</a></p>

	<Subscribe />
</Layout>
<style>
	.post-header .eyebrow {
		margin-bottom: 0.4rem;
	}
	.post-header h1 {
		margin: 0.25rem 0 2rem;
	}
	.prose :global(h2),
	.prose :global(h3) {
		margin-top: 2.4rem;
	}
	.backlink {
		margin-top: 2rem;
	}
</style>
