---
// Base page shell: the <head> (via BaseHead), the top nav, the main column,
// and the footer. Every page and BlogPost.astro render through this so the
// shell lives in exactly one place.
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	article?: { pubDate: Date; updatedDate?: Date };
	profile?: boolean;
	noindex?: boolean;
}

const { title, description, image, article, profile, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			article={article}
			profile={profile}
			noindex={noindex}
		/>
	</head>
	<body>
		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
	</body>
</html>
