---
// Buttondown embed posts straight to their endpoint; no secret in the client.
const BUTTONDOWN_USERNAME = 'valentynkit';
const action = `https://buttondown.email/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---

<form
	action={action}
	method="post"
	target="_blank"
	class="subscribe"
>
	<p class="eyebrow">newsletter</p>
	<label for="bd-email">Systems writing, by email. No spam.</label>
	<div class="row">
		<input type="email" name="email" id="bd-email" placeholder="you@email.com" required />
		<input type="hidden" name="embed" value="1" />
		<button type="submit">subscribe</button>
	</div>
</form>
<style>
	.subscribe {
		border-top: 1px solid var(--border);
		margin-top: 4rem;
		padding-top: 2rem;
		font-family: var(--font-mono);
	}
	.eyebrow {
		margin-bottom: 0.5rem;
	}
	label {
		display: block;
		font-size: 0.9rem;
		color: var(--fg-secondary);
		margin-bottom: 0.9rem;
	}
	.row {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	input {
		flex: 1 1 14rem;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		padding: 0.5rem 0.7rem;
		background: var(--bg);
		color: var(--fg);
		border: 1px solid var(--border);
		border-radius: 4px;
	}
	input:focus {
		outline: none;
		border-color: var(--accent);
	}
	button {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: var(--bg);
		border: none;
		border-radius: 4px;
		cursor: pointer;
		font-weight: 700;
	}
	button:hover {
		opacity: 0.9;
	}
</style>
