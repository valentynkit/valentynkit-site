---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<span>&copy; {year} Valentyn Kit</span>
		<div class="links">
			<a href="https://github.com/valentynkit">github</a>
			<a href="https://www.linkedin.com/in/valentynkit">linkedin</a>
			<a href="https://x.com/valentynkit">x</a>
			<a href="/rss.xml">rss</a>
		</div>
	</div>
</footer>
<Analytics />
<SpeedInsights />
<style>
	footer {
		border-top: 1px solid var(--border);
	}
	.inner {
		max-width: var(--measure);
		margin: 0 auto;
		padding: 1.5rem 1.25rem 2.5rem;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--fg-muted);
	}
	.links {
		display: flex;
		gap: 1rem;
	}
	.inner a {
		color: var(--fg-muted);
		text-decoration: none;
	}
	.inner a:hover {
		color: var(--accent);
	}
</style>
