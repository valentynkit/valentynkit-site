---
// Included on every page via the layouts/pages. Owns metadata, canonical,
// OG/Twitter cards, the serif webfont, and the JSON-LD graph.
import '../styles/global.css';
import { Font } from 'astro:assets';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	article?: { pubDate: Date; updatedDate?: Date };
}

const { title, description, image = '/og-default.png', article } = Astro.props;

const site = Astro.site!;
const canonicalURL = new URL(Astro.url.pathname, site);
const imageURL = new URL(image, site);

// Identity links (handle reused across channels per the IDENTITY rule).
const GITHUB = 'https://github.com/valentynkit';
const LINKEDIN = 'https://www.linkedin.com/in/valentynkit';
const X = 'https://x.com/valentynkit';
const personId = new URL('/#person', site).href;

const person = {
	'@type': 'Person',
	'@id': personId,
	name: 'Valentyn Kit',
	url: site.href,
	jobTitle: 'Distributed-systems & platform engineer',
	sameAs: [GITHUB, LINKEDIN, X],
};
const website = {
	'@type': 'WebSite',
	'@id': new URL('/#website', site).href,
	url: site.href,
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	publisher: { '@id': personId },
};

const graph: Record<string, unknown>[] = [person, website];
if (article) {
	graph.push({
		'@type': 'BlogPosting',
		headline: title,
		description,
		datePublished: article.pubDate.toISOString(),
		dateModified: (article.updatedDate ?? article.pubDate).toISOString(),
		author: { '@id': personId },
		publisher: { '@id': personId },
		mainEntityOfPage: canonicalURL.href,
		url: canonicalURL.href,
		image: imageURL.href,
	});
	graph.push({
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: site.href },
			{ '@type': 'ListItem', position: 2, name: 'Writing', item: new URL('/blog/', site).href },
			{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.href },
		],
	});
}
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="dark" />
<meta name="generator" content={Astro.generator} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', site)}
/>

<Font cssVariable="--font-sans" preload />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Valentyn Kit" />

<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={SITE_TITLE} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
