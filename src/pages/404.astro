---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';
---

<Layout title={`404 · ${SITE_TITLE}`} description="Page not found.">
	<p class="eyebrow">404</p>
	<h1>No such page</h1>
	<p>
		Nothing lives here. The link may be old.
	</p>
	<p class="meta">
		<a href="/">home</a> · <a href="/open-source">open source</a> · <a href="/about">about</a>
	</p>
</Layout>
<style>
	.meta {
		margin-top: 1.5rem;
	}
</style>
