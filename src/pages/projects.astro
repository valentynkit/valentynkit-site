---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const description = 'Side projects in C and Rust: a small Redis, TCP servers across seven I/O models, a row-oriented database, a Solana indexer. Built from scratch to understand the layer underneath.';

// Curated link-out list; the GitHub READMEs are the source of truth.
const projects = [
	{
		name: 'bytekv',
		lang: 'C',
		blurb: 'A small Redis in C: event loop, append-only log, compaction. Built to find out where the line between fast and durable actually gets drawn.',
		href: 'https://github.com/valentynkit/bytekv',
	},
	{
		name: 'building-tcp-servers-in-c',
		lang: 'C',
		blurb: 'One echo server written seven ways, from blocking up through select, poll, epoll, and kqueue. The point was to feel exactly what each I/O model buys you.',
		href: 'https://github.com/valentynkit/building-tcp-servers-in-c',
	},
	{
		name: 'building-tcp-servers-in-rust',
		lang: 'Rust',
		blurb: 'The same exercise in Rust, from blocking up through mio and tokio, with one test that runs across every backend. Async stops being magic once you have hand-written the thing underneath it.',
		href: 'https://github.com/valentynkit/building-tcp-servers-in-rust',
	},
	{
		name: 'RowOrient_DB',
		lang: 'C',
		blurb: 'An in-memory, row-oriented database in C. Built to answer the one question I kept hand-waving past: where do the bytes actually go.',
		href: 'https://github.com/valentynkit/RowOrient_DB',
	},
	{
		name: 'Solarix',
		lang: 'Rust',
		blurb: 'A Solana indexer in Rust. Trajectory work: the on-ramp from building on the chain toward understanding the chain itself.',
		href: 'https://github.com/valentynkit/Solarix',
	},
	{
		name: 'x402_CLI',
		lang: 'Rust',
		blurb: 'A CLI for the x402 payments protocol on Solana. Small, but it moves a real dollar over a spec, which is the fastest way I know to actually learn one.',
		href: 'https://github.com/valentynkit/x402_CLI',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects · ${SITE_TITLE}`} description={description} />
	</head>
	<body>
		<Header />
		<main id="main">
			<h1>Projects</h1>
			<p>
				Side projects, and I'll call them that. Each one is the smaller, wronger
				version of something I depend on, built from scratch until I could see how
				the real thing works. Source and full write-ups are on
				<a href="https://github.com/valentynkit">GitHub</a>.
			</p>
			<ul class="manifest">
				{
					projects.map((p) => (
						<li>
							<div class="row">
								<a class="name" href={p.href}>
									{p.name}
								</a>
								<span class="lang">{p.lang}</span>
							</div>
							<p class="blurb">{p.blurb}</p>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
<style>
	.manifest {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
		border-top: 1px solid var(--border);
	}
	.manifest li {
		padding: 1.05rem 0;
		border-bottom: 1px solid var(--border);
	}
	.row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
	}
	.name {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 1.05rem;
		color: var(--fg-strong);
		text-decoration: none;
	}
	.name:hover {
		color: var(--accent);
	}
	.lang {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--accent);
		white-space: nowrap;
	}
	.blurb {
		color: var(--fg-secondary);
		font-size: 0.95rem;
		margin: 0.3rem 0 0;
	}
</style>
