---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Subscribe from '../components/Subscribe.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Valentyn Kit</h1>
			<p>
				Distributed-systems and platform engineer working from first
				principles, one level below and one level above. Writing about systems
				from the architecture down to the bits: C and Rust, operating systems,
				networking, databases, and building things from scratch to understand them.
			</p>
			<p><a href="/blog/">Read the writing</a> or <a href="/about/">about me</a>.</p>
			<Subscribe />
		</main>
		<Footer />
	</body>
</html>
