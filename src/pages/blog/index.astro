---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const description = 'Writing on systems from first principles: C, Rust, operating systems, networking, and databases.';
---

<Layout title={`Writing · ${SITE_TITLE}`} description={description}>
	<h1>Writing</h1>
	<p class="eyebrow">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
	<ul class="entries">
		{
			posts.map((post) => (
				<li>
					<span class="when">
						<FormattedDate date={post.data.pubDate} />
					</span>
					<div class="what">
						<a class="headline" href={`/blog/${post.id}/`}>
							{post.data.title}
						</a>
						<p class="summary">{post.data.description}</p>
					</div>
				</li>
			))
		}
	</ul>
</Layout>
