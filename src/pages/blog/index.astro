---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const description = 'Writing on systems from first principles: C, Rust, operating systems, networking, and databases.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing · ${SITE_TITLE}`} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="title">
								{post.data.title}
							</a>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="dek">{post.data.description}</p>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
<style>
	ul {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
	}
	li {
		margin-bottom: 2.2rem;
	}
	.title {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 1.15rem;
		color: var(--fg);
		text-decoration: none;
	}
	.title:hover {
		color: var(--accent);
	}
	.date {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--fg-muted);
		margin: 0.25rem 0 0.4rem;
	}
	.dek {
		color: var(--fg-secondary);
		margin: 0;
	}
</style>
